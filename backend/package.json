{
  "name": "yieldvault-backend",
  "version": "1.0.0",
  "description": "YieldVault Stellar RWA Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:smoke": "npm run build && npm run start &",
    "lint": "eslint src",
    "format": "prettier --write src",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "ci:governance": "npm run lint && npm run test && node scripts/check-migrations.js",
    "db:check-drift": "prisma migrate diff --from-schema-datamodel prisma/schema.prisma --to-migrations prisma/migrations --exit-code"
  },
  "keywords": [
    "stellar",
    "vault",
    "rwa",
    "yield"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "dotenv": "^16.3.1",
    "node-cache": "^5.1.2",
    "@prisma/client": "^5.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.1.0",
    "tsx": "^4.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "prettier": "^3.0.0",
    "prisma": "^5.10.0"
  }
}
